# ── AI API Keys (required) ─────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Database backend ────────────────────────────────────────────────────────────
# Options: "sql" (default) or "firestore"
DB_BACKEND=sql

# SQL backend — SQLite for local dev (default), PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./delphee.db
# DATABASE_URL=postgresql+asyncpg://delphee:changeme@localhost:5432/delphee

# Firestore backend — Cloud Run only (auth via service account or ADC)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json  # local only

# ── Email digest (optional) ─────────────────────────────────────────────────────
# SENDGRID_API_KEY=your-sendgrid-key
# ALERT_EMAIL=team@yourcompany.com

# ── App ─────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
PORT=8000

# ── Access control ───────────────────────────────────────────────────────────
# Set this to require a password before anyone can use the app.
# Leave blank to disable (local dev). Use a strong password in production.
# APP_PASSWORD=your-strong-password-here

# ── Docker Compose ──────────────────────────────────────────────────────────────
DB_PASSWORD=changeme
